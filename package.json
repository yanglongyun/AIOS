{
  "name": "aios",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "server/main/index.js",
  "scripts": {
    "predev": "node scripts/start.mjs",
    "dev": "node server/main/index.js & node server/apps/index.js & vite --config gui/vite.config.js gui",
    "prebuild": "node scripts/start.mjs",
    "build": "vite build --config gui/vite.config.js gui",
    "prestart": "node scripts/start.mjs",
    "start": "node server/main/index.js",
    "prestart:apps": "node scripts/start.mjs",
    "start:apps": "node server/apps/index.js",
    "lang:apply": "node scripts/start.mjs --force",
    "lang:reset": "rm -rf .aios",
    "docker": "docker compose -f doc/docker/docker-compose.yml up -d --build",
    "docker:stop": "docker compose -f doc/docker/docker-compose.yml down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^6.0.4",
    "better-sqlite3": "^12.6.2",
    "lucide-vue-next": "^0.576.0",
    "marked": "^17.0.2",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4",
    "ws": "^8.19.0"
  }
}
