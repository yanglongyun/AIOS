{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "server/**/*.ts",
    "apps/**/*.ts",
    "shared/**/*.ts",
    "cli/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "ui",
    "deploy"
  ]
}
