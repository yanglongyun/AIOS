    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.2.4",
    "ws": "^8.21.0"
