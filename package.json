{
  "name": "aios",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "server/system/index.js",
  "scripts": {
    "predev": "node scripts/start.mjs",
    "dev": "AGENT_PORT=9502 AGENT_APPS_PORT=9503 node scripts/run.mjs",
    "prestart": "node scripts/start.mjs",
    "start": "AGENT_PORT=9502 AGENT_APPS_PORT=9503 node scripts/run.mjs",
    "server": "AGENT_PORT=9502 AGENT_APPS_PORT=9503 node scripts/run.mjs",
    "start:main": "AGENT_PORT=9502 AGENT_APPS_PORT=9503 node server/system/index.js",
    "start:apps": "AGENT_APPS_PORT=9503 node server/apps/index.js",
    "prebuild": "node scripts/start.mjs",
    "build": "node node_modules/vite/bin/vite.js build --config ui/vite.config.js ui",
    "ui": "node node_modules/vite/bin/vite.js --config ui/vite.config.js ui",
    "ui:dev": "node node_modules/vite/bin/vite.js --config ui/vite.config.js ui",
    "ui:build": "npm run build",
    "lang:apply": "node scripts/start.mjs --force",
    "check": "find server ui/src scripts -name '*.js' -not -path '*/node_modules/*' -print0 | xargs -0 -n 1 node --check"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^6.0.4",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.4",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.4",
    "vite": "^6.3.5",
    "vue": "^3.5.28",
    "ws": "^8.21.0"
  }
}
